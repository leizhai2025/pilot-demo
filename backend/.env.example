# GitHub Models API token (https://github.com/settings/tokens, "models:read" scope)
# Without this set, the backend runs in DEMO mode and uses a canned tool-call trace
# for the working-paper fill flow so you can still walk through the UX.
GITHUB_TOKEN=

# Model id. See https://github.com/marketplace/models
MODEL_ID=openai/gpt-4o

# GitHub Models inference endpoint (OpenAI-compatible)
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
